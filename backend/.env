# ==============================================================================
# RecommRead Backend Environment Configurations Reference (.env.example)
# Copy this file to '.env' and substitute values for production deployments.
# ==============================================================================

# ── Security & Secrets Management ─────────────────────────────────────────────
# Secret key used for signing JWT access tokens (use a cryptographically secure random value)
# Command to generate: openssl rand -hex 32
SECRET_KEY=replace-this-with-a-secure-random-cryptographic-hash-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database Configurations ────────────────────────────────────────────────────
# PostgreSQL target connection coordinates
# Syntax: postgresql://<user>:<password>@<host>:<port>/<dbname>
POSTGRES_USER=anumanmodi
POSTGRES_PASSWORD=
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=recommread_db



# ── Network & CORS Settings ───────────────────────────────────────────────────
# Application deployment environment mode: development, staging, production
ENVIRONMENT=development
PORT=8000

# JSON serialized array list of trusted origins allowed to hit the REST endpoints
# In production, restrict this strictly to your client domain name values
ALLOWED_CORS_ORIGINS='["https://recommread.com", "https://api.recommread.com"]'


# ── Logging & Monitoring ──────────────────────────────────────────────────────
# Logger output severity: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# Sentry integration DSN key coordinates for analytics and error boundary tracking
SENTRY_DSN=""
